# ─── Configuración de Ambiente para ITO Cloud en Oracle Cloud ───────────────
# 
# Este archivo contiene las variables de entorno para la aplicación.
# IMPORTANTE: Para producción, cambia todos los valores por defecto.
#
# Uso: copiar como .env en la carpeta /ito del servidor Oracle Cloud

# ─ JWT / Seguridad ─────────────────────────────────────────────────────────
JWT_SECRET=SuperSecretKeyParaITOCloud2025XYZ!

# ⚠️  EN PRODUCCIÓN: Genera una clave segura con:
#     openssl rand -base64 32

# ─ PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=joanmiro
POSTGRES_DB=ito_cloud

# ⚠️  EN PRODUCCIÓN: Cambia "joanmiro" por una contraseña fuerte

# ─ Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redispass123

# ⚠️  EN PRODUCCIÓN: Cambia esta contraseña

# ─ MinIO / Almacenamiento ─────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# ⚠️  EN PRODUCCIÓN: Cambia ambas credenciales

# ─ Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=Information

# ─ Configuración de la Aplicación ────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production

# ─ Puertos (generalmente no cambiar a menos que haya conflictos) ────────────
API_PORT=80
WEB_PORT=8081
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
POSTGRES_PORT=5432
REDIS_PORT=6379
