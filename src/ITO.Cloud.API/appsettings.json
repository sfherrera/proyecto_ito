{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=ito_cloud;Username=postgres;Password=joanmiro"
  },
  "JwtSettings": {
    "SecretKey": "ITO_CLOUD_SECRET_KEY_CHANGE_IN_PRODUCTION_MIN_32_CHARS",
    "Issuer": "ITO.Cloud.API",
    "Audience": "ITO.Cloud.Clients",
    "ExpirationMinutes": 480
  },
  "MinIOSettings": {
    "Endpoint": "localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "BucketName": "ito-cloud",
    "UseSSL": false
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/ito-cloud-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
