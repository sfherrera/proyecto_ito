@implements IDisposable

<MudNavMenu>
    <!-- Dashboard: todos -->
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
        @L["nav.dashboard"]
    </MudNavLink>

    <!-- Grupo Proyectos -->
    <AuthorizeView Roles="SuperAdmin,AdminTenant,Director,Supervisor,Inspector">
        <MudNavGroup Title="@L["nav.projects_group"]" Icon="@Icons.Material.Filled.Folder" Expanded="true">
            <AuthorizeView Roles="SuperAdmin,AdminTenant,Director" Context="_mgmt">
                <MudNavLink Href="/companies" Icon="@Icons.Material.Filled.Business">
                    @L["nav.companies"]
                </MudNavLink>
            </AuthorizeView>
            <MudNavLink Href="/projects" Icon="@Icons.Material.Filled.AccountTree">
                @L["nav.projects"]
            </MudNavLink>
            <AuthorizeView Roles="SuperAdmin,AdminTenant,Director,Supervisor" Context="_ops">
                <MudNavLink Href="/specialties" Icon="@Icons.Material.Filled.Category">
                    @L["nav.specialties"]
                </MudNavLink>
                <MudNavLink Href="/contractors" Icon="@Icons.Material.Filled.Engineering">
                    @L["nav.contractors"]
                </MudNavLink>
            </AuthorizeView>
        </MudNavGroup>
    </AuthorizeView>

    <!-- Grupo Inspecciones -->
    <MudNavGroup Title="@L["nav.inspections_group"]" Icon="@Icons.Material.Filled.Assignment" Expanded="true">
        <MudNavLink Href="/inspections" Icon="@Icons.Material.Filled.CheckCircle">
            @L["nav.inspections"]
        </MudNavLink>
        <AuthorizeView Roles="SuperAdmin,AdminTenant,Director,Supervisor,Inspector">
            <MudNavLink Href="/observations" Icon="@Icons.Material.Filled.Warning">
                @L["nav.observations"]
            </MudNavLink>
        </AuthorizeView>
        <AuthorizeView Roles="SuperAdmin,AdminTenant,Director,Supervisor,Inspector">
            <MudNavLink Href="/templates" Icon="@Icons.Material.Filled.ListAlt">
                @L["nav.templates"]
            </MudNavLink>
        </AuthorizeView>
    </MudNavGroup>

    <!-- Documentación -->
    <AuthorizeView Roles="SuperAdmin,AdminTenant,Director,Supervisor,Inspector">
        <MudNavLink Href="/documents" Icon="@Icons.Material.Filled.Description">
            @L["nav.documents"]
        </MudNavLink>
    </AuthorizeView>

    <!-- Reportes -->
    <AuthorizeView Roles="SuperAdmin,AdminTenant,Director,Supervisor">
        <MudNavGroup Title="@L["nav.reports_group"]" Icon="@Icons.Material.Filled.Assessment">
            <MudNavLink Href="/reports" Icon="@Icons.Material.Filled.PictureAsPdf">
                @L["nav.reports"]
            </MudNavLink>
        </MudNavGroup>
    </AuthorizeView>

    <!-- Administracion -->
    <AuthorizeView Roles="SuperAdmin,AdminTenant,Director">
        <MudDivider Class="my-2" />
        <MudNavLink Href="/users" Icon="@Icons.Material.Filled.People">
            @L["nav.users"]
        </MudNavLink>
    </AuthorizeView>

    <!-- Idioma -->
    <MudDivider Class="my-2" />
    <MudNavLink Href="/settings/language" Icon="@Icons.Material.Filled.Language">
        @L["nav.language"]
    </MudNavLink>
</MudNavMenu>

@code {
    protected override void OnInitialized()
    {
        L.OnChange += OnLanguageChanged;
    }

    private void OnLanguageChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        L.OnChange -= OnLanguageChanged;
    }
}
