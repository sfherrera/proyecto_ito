@page "/companies"
@attribute [Authorize(Roles = "SuperAdmin,AdminTenant,Director")]
@implements IDisposable

@using ITO.Cloud.Web.Auth
@inject ItoApiService Api
@inject ISnackbar Snackbar

<PageTitle>@L["companies.title"] — ITO Cloud</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5">
        <MudIcon Icon="@Icons.Material.Filled.Business" Class="mr-2" />@L["companies.title"]
    </MudText>
    <MudSpacer />
    <HelpButton Module="companies" />
    <AuthorizeView Roles="SuperAdmin,AdminTenant">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenCreateDialog">
            @L["companies.new"]
        </MudButton>
    </AuthorizeView>
</MudStack>

<MudPaper Elevation="2">
    <MudTable Items="_companies" Hover="true" Striped="true" Loading="_loading"
              Filter="FilterFunc" Dense="true">
        <ToolBarContent>
            <MudTextField @bind-Value="_searchText" Placeholder="@L["common.search"]" Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"
                          Class="mt-0" Immediate="true" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>@L["common.name"]</MudTh>
            <MudTh>@L["common.rut"]</MudTh>
            <MudTh>@L["common.type"]</MudTh>
            <MudTh>@L["common.status"]</MudTh>
            <MudTh>@L["common.actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd>@context.Rut</MudTd>
            <MudTd>@context.CompanyType</MudTd>
            <MudTd>
                <MudChip T="string" Color="@(context.IsActive ? Color.Success : Color.Default)" Size="Size.Small">
                    @(context.IsActive ? L["common.active_f"] : L["common.inactive_f"])
                </MudChip>
            </MudTd>
            <MudTd>
                <AuthorizeView Roles="SuperAdmin,AdminTenant" Context="_ac">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                   OnClick="() => OpenEditDialog(context.Id)" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   OnClick="() => DeleteCompany(context.Id)" />
                </AuthorizeView>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4">@L["companies.no_records"]</MudText>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

<!-- Dialog crear / editar empresa -->
<MudDialog @bind-Visible="_showDialog">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editId.HasValue ? L["companies.edit"] : L["companies.new"])</MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="_form.Name" Label="@(L["common.name"] + " *")" Variant="Variant.Outlined" FullWidth="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_form.Rut" Label="@L["common.rut"]" Variant="Variant.Outlined" FullWidth="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect @bind-Value="_form.CompanyType" Label="@(L["common.type"] + " *")" Variant="Variant.Outlined" FullWidth="true">
                    <MudSelectItem Value="@("Contratista")">@L["companies.type_contractor"]</MudSelectItem>
                    <MudSelectItem Value="@("Mandante")">@L["companies.type_mandante"]</MudSelectItem>
                    <MudSelectItem Value="@("Inspeccion")">@L["companies.type_inspection"]</MudSelectItem>
                    <MudSelectItem Value="@("Subcontratista")">@L["companies.type_subcontractor"]</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_form.Email" Label="@L["common.email"]" Variant="Variant.Outlined" FullWidth="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_form.Phone" Label="@L["common.phone"]" Variant="Variant.Outlined" FullWidth="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_form.City" Label="@L["common.city"]" Variant="Variant.Outlined" FullWidth="true" />
            </MudItem>
            @if (_editId.HasValue)
            {
                <MudItem xs="12">
                    <MudSwitch @bind-Value="_form.IsActive" Label="@L["common.active_f"]" Color="Color.Success" />
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showDialog = false">@L["common.cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveCompany" Disabled="_saving">
            @(_saving ? L["common.saving"] : L["common.save"])
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<CompanyDto> _companies = [];
    private bool   _loading    = true;
    private bool   _showDialog = false;
    private bool   _saving     = false;
    private string _searchText = string.Empty;
    private Guid?  _editId;
    private CompanyForm _form = new();

    protected override async Task OnInitializedAsync()
    {
        L.OnChange += StateHasChanged;
        await LoadCompanies();
    }

    public void Dispose()
    {
        L.OnChange -= StateHasChanged;
    }

    private async Task LoadCompanies()
    {
        _loading = true;
        try   { _companies = await Api.GetCompaniesAsync(); }
        catch { Snackbar.Add(L["companies.error_loading"], Severity.Error); }
        finally { _loading = false; }
    }

    private bool FilterFunc(CompanyDto c) =>
        string.IsNullOrEmpty(_searchText) ||
        c.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
        (c.Rut?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false);

    private void OpenCreateDialog()
    {
        _editId = null;
        _form   = new();
        _showDialog = true;
    }

    private async Task OpenEditDialog(Guid id)
    {
        _editId = id;
        _form   = new();
        _showDialog = true;
        try
        {
            var detail = await Api.GetCompanyByIdAsync(id);
            if (detail != null)
            {
                _form.Name        = detail.Name;
                _form.Rut         = detail.Rut;
                _form.Email       = detail.Email;
                _form.Phone       = detail.Phone;
                _form.City        = detail.City;
                _form.CompanyType = detail.CompanyType;
                _form.IsActive    = detail.IsActive;
            }
        }
        catch { Snackbar.Add(L["companies.error_loading"], Severity.Error); }
    }

    private async Task SaveCompany()
    {
        if (string.IsNullOrWhiteSpace(_form.Name)) return;
        _saving = true;

        bool ok;
        if (_editId.HasValue)
        {
            ok = await Api.UpdateCompanyAsync(_editId.Value, new
            {
                _form.Name, _form.Rut, BusinessName = _form.Name,
                _form.CompanyType, _form.Email, _form.Phone, _form.City,
                _form.IsActive, Address = (string?)null, Region = (string?)null,
                Website = (string?)null, Notes = (string?)null
            });
        }
        else
        {
            ok = await Api.CreateCompanyAsync(new
            {
                _form.Name, _form.Rut, BusinessName = _form.Name,
                CompanyType = _form.CompanyType, _form.Email, _form.Phone, _form.City
            });
        }

        _saving     = false;
        _showDialog = false;
        if (ok) { Snackbar.Add(_editId.HasValue ? L["companies.updated"] : L["companies.created"], Severity.Success); await LoadCompanies(); }
        else    Snackbar.Add(L["companies.error_saving"], Severity.Error);
    }

    private async Task DeleteCompany(Guid id)
    {
        var ok = await Api.DeleteCompanyAsync(id);
        if (ok) { Snackbar.Add(L["companies.deleted"], Severity.Success); await LoadCompanies(); }
        else    Snackbar.Add(L["common.error_deleting"], Severity.Error);
    }

    private class CompanyForm
    {
        public string Name        { get; set; } = string.Empty;
        public string? Rut        { get; set; }
        public string? Email      { get; set; }
        public string? Phone      { get; set; }
        public string? City       { get; set; }
        public string CompanyType { get; set; } = "Contratista";
        public bool   IsActive    { get; set; } = true;
    }
}
