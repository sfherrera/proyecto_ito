@page "/contractors"
@attribute [Authorize(Roles = "SuperAdmin,AdminTenant,Director,Supervisor")]
@implements IDisposable

@using ITO.Cloud.Web.Auth
@inject ItoApiService Api
@inject ISnackbar Snackbar

<PageTitle>@L["contractors.title"] — ITO Cloud</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5">
        <MudIcon Icon="@Icons.Material.Filled.Engineering" Class="mr-2" />@L["contractors.title"]
    </MudText>
    <MudSpacer />
    <HelpButton Module="contractors" />
    <AuthorizeView Roles="SuperAdmin,AdminTenant">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenCreateDialog">
            @L["contractors.new"]
        </MudButton>
    </AuthorizeView>
</MudStack>

<MudPaper Elevation="2">
    <MudTable Items="_contractors" Hover="true" Striped="true" Loading="_loading"
              Filter="FilterFunc" Dense="true">
        <ToolBarContent>
            <MudTextField @bind-Value="_searchText" Placeholder="@L["common.search"]" Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"
                          Class="mt-0" Immediate="true" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>@L["common.name"]</MudTh>
            <MudTh>@L["common.rut"]</MudTh>
            <MudTh>@L["contractors.contact"]</MudTh>
            <MudTh>@L["contractors.contact_email"]</MudTh>
            <MudTh>@L["common.status"]</MudTh>
            <MudTh>@L["common.actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd>@context.Rut</MudTd>
            <MudTd>@context.ContactName</MudTd>
            <MudTd>@context.ContactEmail</MudTd>
            <MudTd>
                <MudChip T="string" Color="@(context.IsActive ? Color.Success : Color.Default)" Size="Size.Small">
                    @(context.IsActive ? L["common.active"] : L["common.inactive"])
                </MudChip>
            </MudTd>
            <MudTd>
                <AuthorizeView Roles="SuperAdmin,AdminTenant" Context="_ac">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                   OnClick="() => OpenEditDialog(context)" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   OnClick="() => DeleteContractor(context.Id)" />
                </AuthorizeView>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4">@L["contractors.no_records"]</MudText>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

<!-- Dialog crear / editar contratista -->
<MudDialog @bind-Visible="_showDialog">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editId.HasValue ? L["contractors.edit"] : L["contractors.new"])</MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="_form.Name" Label="@(L["common.name"] + " *")" Variant="Variant.Outlined" FullWidth="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_form.Rut" Label="@L["common.rut"]" Variant="Variant.Outlined" FullWidth="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_form.ContactName" Label="@L["contractors.contact_name"]" Variant="Variant.Outlined" FullWidth="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_form.ContactEmail" Label="@L["contractors.contact_email"]" Variant="Variant.Outlined" FullWidth="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_form.ContactPhone" Label="@L["contractors.contact_phone"]" Variant="Variant.Outlined" FullWidth="true" />
            </MudItem>
            @if (_editId.HasValue)
            {
                <MudItem xs="12">
                    <MudSwitch @bind-Value="_form.IsActive" Label="@L["common.active"]" Color="Color.Success" />
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showDialog = false">@L["common.cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveContractor" Disabled="_saving">
            @(_saving ? L["common.saving"] : L["common.save"])
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<ContractorDto> _contractors = [];
    private bool   _loading    = true;
    private bool   _showDialog = false;
    private bool   _saving     = false;
    private string _searchText = string.Empty;
    private Guid?  _editId;
    private ContractorForm _form = new();

    protected override async Task OnInitializedAsync()
    {
        L.OnChange += StateHasChanged;
        await LoadContractors();
    }

    public void Dispose()
    {
        L.OnChange -= StateHasChanged;
    }

    private async Task LoadContractors()
    {
        _loading = true;
        try   { _contractors = await Api.GetContractorsAsync(); }
        catch { Snackbar.Add(L["contractors.error_loading"], Severity.Error); }
        finally { _loading = false; }
    }

    private bool FilterFunc(ContractorDto c) =>
        string.IsNullOrEmpty(_searchText) ||
        c.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
        (c.Rut?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
        (c.ContactName?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false);

    private void OpenCreateDialog()
    {
        _editId = null;
        _form   = new();
        _showDialog = true;
    }

    private void OpenEditDialog(ContractorDto item)
    {
        _editId = item.Id;
        _form   = new()
        {
            Name         = item.Name,
            Rut          = item.Rut,
            ContactName  = item.ContactName,
            ContactEmail = item.ContactEmail,
            ContactPhone = item.ContactPhone,
            IsActive     = item.IsActive
        };
        _showDialog = true;
    }

    private async Task SaveContractor()
    {
        if (string.IsNullOrWhiteSpace(_form.Name)) return;
        _saving = true;

        bool ok;
        if (_editId.HasValue)
        {
            ok = await Api.UpdateContractorAsync(_editId.Value, new
            {
                _form.Name, _form.Rut, _form.ContactName,
                _form.ContactEmail, _form.ContactPhone, _form.IsActive
            });
        }
        else
        {
            ok = await Api.CreateContractorAsync(new
            {
                _form.Name, _form.Rut, _form.ContactName,
                _form.ContactEmail, _form.ContactPhone
            });
        }

        _saving     = false;
        _showDialog = false;
        if (ok) { Snackbar.Add(_editId.HasValue ? L["contractors.updated"] : L["contractors.created"], Severity.Success); await LoadContractors(); }
        else    Snackbar.Add(L["contractors.error_saving"], Severity.Error);
    }

    private async Task DeleteContractor(Guid id)
    {
        var ok = await Api.DeleteContractorAsync(id);
        if (ok) { Snackbar.Add(L["contractors.deleted"], Severity.Success); await LoadContractors(); }
        else    Snackbar.Add(L["contractors.error_deleting"], Severity.Error);
    }

    private class ContractorForm
    {
        public string  Name         { get; set; } = string.Empty;
        public string? Rut          { get; set; }
        public string? ContactName  { get; set; }
        public string? ContactEmail { get; set; }
        public string? ContactPhone { get; set; }
        public bool    IsActive     { get; set; } = true;
    }
}
