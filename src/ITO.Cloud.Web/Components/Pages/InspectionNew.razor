@page "/inspections/new"

@inject ItoApiService Api
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Nueva Inspección — ITO Cloud</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick='() => Nav.NavigateTo("/inspections")' />
    <MudText Typo="Typo.h5">Nueva Inspección</MudText>
</MudStack>

<MudPaper Elevation="2" Class="pa-6" Style="max-width:800px">
    <MudGrid>
        <MudItem xs="12">
            <MudTextField @bind-Value="_form.Title" Label="Título *" Variant="Variant.Outlined" FullWidth="true" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudSelect @bind-Value="_form.ProjectId" Label="Proyecto *" Variant="Variant.Outlined" FullWidth="true">
                @foreach (var p in _projects)
                {
                    <MudSelectItem Value="@p.Id">@p.Name (@p.Code)</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudSelect @bind-Value="_form.TemplateId" Label="Plantilla *" Variant="Variant.Outlined" FullWidth="true">
                @foreach (var t in _templates)
                {
                    <MudSelectItem Value="@t.Id">@t.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudSelect @bind-Value="_form.InspectionType" Label="Tipo de Inspección" Variant="Variant.Outlined" FullWidth="true">
                <MudSelectItem Value="@("ordinaria")">Ordinaria</MudSelectItem>
                <MudSelectItem Value="@("extraordinaria")">Extraordinaria</MudSelectItem>
                <MudSelectItem Value="@("reinspeccion")">Reinspección</MudSelectItem>
                <MudSelectItem Value="@("recepcion")">Recepción</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudSelect @bind-Value="_form.Priority" Label="Prioridad" Variant="Variant.Outlined" FullWidth="true">
                <MudSelectItem Value="@("Baja")">Baja</MudSelectItem>
                <MudSelectItem Value="@("Normal")">Normal</MudSelectItem>
                <MudSelectItem Value="@("Alta")">Alta</MudSelectItem>
                <MudSelectItem Value="@("Critica")">Crítica</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudDatePicker @bind-Date="_form.ScheduledDate" Label="Fecha Programada *" Variant="Variant.Outlined"
                           DateFormat="dd/MM/yyyy" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudSelect @bind-Value="_form.AssignedToId" Label="Asignar a Inspector" Variant="Variant.Outlined" FullWidth="true">
                <MudSelectItem Value="@(Guid.Empty)">— Sin asignar —</MudSelectItem>
                @foreach (var u in _users)
                {
                    <MudSelectItem Value="@u.Id">@u.FullName</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12">
            <MudTextField @bind-Value="_form.Description" Label="Descripción / Notas" Variant="Variant.Outlined"
                          FullWidth="true" Lines="3" />
        </MudItem>
    </MudGrid>

    <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-6" Spacing="2">
        <MudButton Variant="Variant.Outlined" OnClick='() => Nav.NavigateTo("/inspections")'>Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="_saving">
            @(_saving ? "Guardando..." : "Crear Inspección")
        </MudButton>
    </MudStack>
</MudPaper>

@code {
    private List<ProjectDto>      _projects  = [];
    private List<TemplateItemDto> _templates = [];
    private List<UserDto>         _users     = [];
    private bool _saving = false;
    private InspectionForm _form = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var t1 = Api.GetProjectsAsync();
            var t2 = Api.GetTemplatesAsync();
            var t3 = Api.GetUsersAsync();
            await Task.WhenAll(t1, t2, t3);
            _projects  = t1.Result;
            _templates = t2.Result;
            _users     = t3.Result;
        }
        catch { Snackbar.Add("Error cargando datos", Severity.Error); }
    }

    private async Task Save()
    {
        if (_form.ProjectId == Guid.Empty || _form.TemplateId == Guid.Empty || !_form.ScheduledDate.HasValue)
        {
            Snackbar.Add("Proyecto, plantilla y fecha son requeridos", Severity.Warning);
            return;
        }
        _saving = true;
        var ok = await Api.CreateInspectionAsync(new
        {
            _form.ProjectId,
            _form.TemplateId,
            _form.Title,
            ScheduledDate  = _form.ScheduledDate!.Value,
            InspectionType = _form.InspectionType,
            Priority       = _form.Priority,
            AssignedToId   = _form.AssignedToId == Guid.Empty ? (Guid?)null : _form.AssignedToId,
            Description    = _form.Description
        });
        _saving = false;
        if (ok) { Snackbar.Add("Inspección creada", Severity.Success); Nav.NavigateTo("/inspections"); }
        else    Snackbar.Add("Error al crear inspección", Severity.Error);
    }

    private class InspectionForm
    {
        public Guid      ProjectId      { get; set; }
        public Guid      TemplateId     { get; set; }
        public string    Title          { get; set; } = string.Empty;
        public string    InspectionType { get; set; } = "ordinaria";
        public string    Priority       { get; set; } = "Normal";
        public DateTime? ScheduledDate  { get; set; }
        public Guid      AssignedToId   { get; set; }
        public string?   Description    { get; set; }
    }
}
