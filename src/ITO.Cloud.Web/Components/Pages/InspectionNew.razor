@page "/inspections/new"
@attribute [Authorize(Roles = "SuperAdmin,AdminTenant,Director,Supervisor,Inspector")]
@implements IDisposable

@inject ItoApiService Api
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>@L["inspections.new"] — ITO Cloud</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick='() => Nav.NavigateTo("/inspections")' />
    <MudText Typo="Typo.h5">@L["inspections.new"]</MudText>
</MudStack>

<MudPaper Elevation="2" Class="pa-6" Style="max-width:800px">
    <MudGrid>
        <MudItem xs="12">
            <MudTextField @bind-Value="_form.Title" Label="@(L["common.title"] + " *")" Variant="Variant.Outlined" FullWidth="true" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudSelect @bind-Value="_form.ProjectId" Label="@(L["reports.project"] + " *")" Variant="Variant.Outlined" FullWidth="true">
                @foreach (var p in _projects)
                {
                    <MudSelectItem Value="@p.Id">@p.Name (@p.Code)</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudSelect @bind-Value="_form.TemplateId" Label="@(L["inspections.template"] + " *")" Variant="Variant.Outlined" FullWidth="true">
                @foreach (var t in _templates)
                {
                    <MudSelectItem Value="@t.Id">@t.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudSelect @bind-Value="_form.InspectionType" Label="@L["inspections.type"]" Variant="Variant.Outlined" FullWidth="true">
                <MudSelectItem Value="@("ordinaria")">@L["inspections.type_ordinary"]</MudSelectItem>
                <MudSelectItem Value="@("extraordinaria")">@L["inspections.type_extraordinary"]</MudSelectItem>
                <MudSelectItem Value="@("reinspeccion")">@L["inspections.type_reinspection"]</MudSelectItem>
                <MudSelectItem Value="@("recepcion")">@L["inspections.type_reception"]</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudSelect @bind-Value="_form.Priority" Label="@L["inspections.priority"]" Variant="Variant.Outlined" FullWidth="true">
                <MudSelectItem Value="@("Baja")">@L["inspections.priority_low"]</MudSelectItem>
                <MudSelectItem Value="@("Normal")">@L["inspections.priority_normal"]</MudSelectItem>
                <MudSelectItem Value="@("Alta")">@L["inspections.priority_high"]</MudSelectItem>
                <MudSelectItem Value="@("Critica")">@L["inspections.priority_critical"]</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudDatePicker @bind-Date="_form.ScheduledDate" Label="@(L["inspections.scheduled_date"] + " *")" Variant="Variant.Outlined"
                           DateFormat="dd/MM/yyyy" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudSelect @bind-Value="_form.AssignedToId" Label="@L["inspections.assign_inspector"]" Variant="Variant.Outlined" FullWidth="true">
                <MudSelectItem Value="@(Guid.Empty)">@L["inspections.unassigned"]</MudSelectItem>
                @foreach (var u in _users)
                {
                    <MudSelectItem Value="@u.Id">@u.FullName</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12">
            <MudTextField @bind-Value="_form.Description" Label="@L["inspections.description_notes"]" Variant="Variant.Outlined"
                          FullWidth="true" Lines="3" />
        </MudItem>
    </MudGrid>

    <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-6" Spacing="2">
        <MudButton Variant="Variant.Outlined" OnClick='() => Nav.NavigateTo("/inspections")'>@L["common.cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="_saving">
            @(_saving ? L["common.saving"] : L["inspections.new"])
        </MudButton>
    </MudStack>
</MudPaper>

@code {
    private List<ProjectDto>      _projects  = [];
    private List<TemplateItemDto> _templates = [];
    private List<UserDto>         _users     = [];
    private bool _saving = false;
    private InspectionForm _form = new();

    protected override async Task OnInitializedAsync()
    {
        L.OnChange += StateHasChanged;
        try
        {
            var t1 = Api.GetProjectsAsync();
            var t2 = Api.GetTemplatesAsync();
            var t3 = Api.GetUsersAsync();
            await Task.WhenAll(t1, t2, t3);
            _projects  = t1.Result;
            _templates = t2.Result;
            _users     = t3.Result;
        }
        catch { Snackbar.Add(L["common.error_loading"], Severity.Error); }
    }

    public void Dispose() { L.OnChange -= StateHasChanged; }

    private async Task Save()
    {
        if (_form.ProjectId == Guid.Empty || _form.TemplateId == Guid.Empty || !_form.ScheduledDate.HasValue)
        {
            Snackbar.Add(L["inspections.validation_required"], Severity.Warning);
            return;
        }
        _saving = true;
        var ok = await Api.CreateInspectionAsync(new
        {
            _form.ProjectId,
            _form.TemplateId,
            _form.Title,
            ScheduledDate  = _form.ScheduledDate!.Value,
            InspectionType = _form.InspectionType,
            Priority       = _form.Priority,
            AssignedToId   = _form.AssignedToId == Guid.Empty ? (Guid?)null : _form.AssignedToId,
            Description    = _form.Description
        });
        _saving = false;
        if (ok) { Snackbar.Add(L["inspections.created"], Severity.Success); Nav.NavigateTo("/inspections"); }
        else    Snackbar.Add(L["inspections.error_creating"], Severity.Error);
    }

    private class InspectionForm
    {
        public Guid      ProjectId      { get; set; }
        public Guid      TemplateId     { get; set; }
        public string    Title          { get; set; } = string.Empty;
        public string    InspectionType { get; set; } = "ordinaria";
        public string    Priority       { get; set; } = "Normal";
        public DateTime? ScheduledDate  { get; set; }
        public Guid      AssignedToId   { get; set; }
        public string?   Description    { get; set; }
    }
}
