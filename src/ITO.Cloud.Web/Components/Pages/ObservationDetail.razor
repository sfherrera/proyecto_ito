@page "/observations/{Id:guid}"
@attribute [Authorize(Roles = "SuperAdmin,AdminTenant,Director,Supervisor,Inspector")]
@implements IDisposable

@using ITO.Cloud.Web.Auth
@inject ItoApiService Api
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>@L["observations.title"] — ITO Cloud</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Warning" />
}
else if (_obs == null)
{
    <MudAlert Severity="Severity.Error">@L["observations.not_found"]</MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Wrap="Wrap.Wrap">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick='() => Nav.NavigateTo("/observations")' />
        <MudText Typo="Typo.h5">@_obs.Code</MudText>
        <MudChip T="string" Color="@GetSeverityColor(_obs.Severity)" Size="Size.Small">@_obs.Severity</MudChip>
        <MudChip T="string" Color="@GetStatusColor(_obs.Status)" Size="Size.Small">@_obs.Status</MudChip>
        <MudSpacer />
        <HelpButton Module="observation-detail" />
        @if (_obs.Status != "Cerrada" && _obs.Status != "Rechazada")
        {
            <AuthorizeView Roles="SuperAdmin,AdminTenant,Director,Supervisor">
                <MudButton Variant="Variant.Outlined" Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.CheckCircle"
                           OnClick="OpenCloseDialog" Disabled="_working">
                    @L["observations.close"]
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                           StartIcon="@Icons.Material.Filled.Refresh"
                           OnClick="OpenReviewDialog" Disabled="_working">
                    @L["observations.in_review"]
                </MudButton>
            </AuthorizeView>
        }
    </MudStack>

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudPaper Elevation="2" Class="pa-4">
                <MudText Typo="Typo.subtitle1" Class="mb-3">@L["observations.detail"]</MudText>
                <MudText Typo="Typo.body1" Class="mb-3">@_obs.Title</MudText>
                <MudText Class="mud-text-secondary">@_obs.Description</MudText>
                <MudDivider Class="my-3" />
                <MudList T="string" Dense="true">
                    <MudListItem><b>@L["observations.category"]:</b> @(_obs.Category ?? "—")</MudListItem>
                    <MudListItem><b>@L["observations.location"]:</b> @(_obs.LocationDescription ?? "—")</MudListItem>
                    <MudListItem><b>@L["observations.assigned_to"]:</b> @(_obs.AssignedToName ?? "—")</MudListItem>
                    <MudListItem><b>@L["observations.contractor"]:</b> @(_obs.ContractorName ?? "—")</MudListItem>
                    <MudListItem><b>@L["observations.due_date_label"]:</b> @(_obs.DueDate ?? "—")</MudListItem>
                    <MudListItem><b>@L["observations.detected_at"]:</b> @_obs.DetectedAt.ToString("dd/MM/yyyy")</MudListItem>
                    @if (_obs.ClosedAt.HasValue)
                    {
                        <MudListItem><b>@L["observations.closed_at"]:</b> @_obs.ClosedAt.Value.ToString("dd/MM/yyyy")</MudListItem>
                    }
                </MudList>
            </MudPaper>
        </MudItem>

        @if (_obs.History?.Count > 0)
        {
            <MudItem xs="12" md="6">
                <MudPaper Elevation="2" Class="pa-4">
                    <MudText Typo="Typo.subtitle1" Class="mb-3">@L["observations.history"]</MudText>
                    <MudTimeline TimelinePosition="TimelinePosition.Start">
                        @foreach (var h in _obs.History)
                        {
                            <MudTimelineItem Color="Color.Primary" Size="Size.Small">
                                <MudText Typo="Typo.body2"><b>@h.Action</b></MudText>
                                @if (!string.IsNullOrEmpty(h.Comment))
                                {
                                    <MudText Typo="Typo.caption">@h.Comment</MudText>
                                }
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    @h.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                </MudText>
                            </MudTimelineItem>
                        }
                    </MudTimeline>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
}

<!-- Dialog cambiar estado -->
<MudDialog @bind-Visible="_showStatusDialog">
    <TitleContent><MudText Typo="Typo.h6">@L["observations.change_status"]</MudText></TitleContent>
    <DialogContent>
        <MudText Class="mb-3">@L["observations.new_status"] <b>@_newStatus</b></MudText>
        <MudTextField @bind-Value="_statusComment" Label="@L["observations.comment"]" Variant="Variant.Outlined"
                      FullWidth="true" Lines="3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showStatusDialog = false">@L["common.cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ChangeStatus">@L["common.confirm"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public Guid Id { get; set; }

    private ObservationDetailDto? _obs;
    private bool   _loading          = true;
    private bool   _working          = false;
    private bool   _showStatusDialog = false;
    private string _newStatus        = string.Empty;
    private string _statusComment    = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        L.OnChange += StateHasChanged;
        try   { _obs = await Api.GetObservationByIdAsync(Id); }
        catch { Snackbar.Add(L["observations.error_loading_detail"], Severity.Error); }
        finally { _loading = false; }
    }

    public void Dispose() { L.OnChange -= StateHasChanged; }

    private void OpenCloseDialog()   => OpenStatusDialog("Cerrada");
    private void OpenReviewDialog()  => OpenStatusDialog("EnRevision");

    private void OpenStatusDialog(string newStatus)
    {
        _newStatus        = newStatus;
        _statusComment    = string.Empty;
        _showStatusDialog = true;
    }

    private async Task ChangeStatus()
    {
        _showStatusDialog = false;
        _working          = true;
        bool ok;
        if (_newStatus == "Cerrada")
            ok = await Api.CloseObservationAsync(Id, _statusComment);
        else
            ok = await Api.UpdateObservationStatusAsync(Id, new { NewStatus = _newStatus, Comment = _statusComment });

        if (ok) { Snackbar.Add(L["observations.status_updated"], Severity.Success); _obs = await Api.GetObservationByIdAsync(Id); }
        else    Snackbar.Add(L["observations.error_updating_status"], Severity.Error);
        _working = false;
    }

    private static Color GetSeverityColor(string s) => s switch
    {
        "Critica" => Color.Error,
        "Alta"    => Color.Warning,
        "Media"   => Color.Info,
        _         => Color.Default
    };

    private static Color GetStatusColor(string s) => s switch
    {
        "Abierta"    => Color.Warning,
        "EnRevision" => Color.Info,
        "Cerrada"    => Color.Success,
        "Rechazada"  => Color.Error,
        _            => Color.Default
    };
}
