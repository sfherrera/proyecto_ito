@page "/observations/new"
@attribute [Authorize(Roles = "SuperAdmin,AdminTenant,Director,Supervisor,Inspector")]
@implements IDisposable

@inject ItoApiService Api
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>@L["observations.new"] — ITO Cloud</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick='() => Nav.NavigateTo("/observations")' />
    <MudText Typo="Typo.h5">@L["observations.new"]</MudText>
</MudStack>

<MudPaper Elevation="2" Class="pa-6" Style="max-width:800px">
    <MudGrid>
        <MudItem xs="12">
            <MudTextField @bind-Value="_form.Title" Label="@(L["common.title"] + " *")" Variant="Variant.Outlined" FullWidth="true" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudSelect @bind-Value="_form.ProjectId" Label="@(L["reports.project"] + " *")" Variant="Variant.Outlined" FullWidth="true">
                @foreach (var p in _projects)
                {
                    <MudSelectItem Value="@p.Id">@p.Name (@p.Code)</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudSelect @bind-Value="_form.Severity" Label="@(L["observations.severity"] + " *")" Variant="Variant.Outlined" FullWidth="true">
                <MudSelectItem Value="@("Baja")">@L["observations.severity_low"]</MudSelectItem>
                <MudSelectItem Value="@("Media")">@L["observations.severity_medium"]</MudSelectItem>
                <MudSelectItem Value="@("Alta")">@L["observations.severity_high"]</MudSelectItem>
                <MudSelectItem Value="@("Critica")">@L["observations.severity_critical"]</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12">
            <MudTextField @bind-Value="_form.Description" Label="@(L["common.description"] + " *")" Variant="Variant.Outlined"
                          FullWidth="true" Lines="4" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudTextField @bind-Value="_form.Category" Label="@L["observations.category"]" Variant="Variant.Outlined" FullWidth="true" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudTextField @bind-Value="_form.LocationDescription" Label="@L["observations.location"]" Variant="Variant.Outlined" FullWidth="true" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudSelect @bind-Value="_form.AssignedToId" Label="@L["observations.assign_to"]" Variant="Variant.Outlined" FullWidth="true">
                <MudSelectItem Value="@(Guid.Empty)">@L["inspections.unassigned"]</MudSelectItem>
                @foreach (var u in _users)
                {
                    <MudSelectItem Value="@u.Id">@u.FullName</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudDatePicker @bind-Date="_form.DueDate" Label="@L["observations.due_date_label"]" Variant="Variant.Outlined"
                           DateFormat="dd/MM/yyyy" />
        </MudItem>
        <MudItem xs="12">
            <MudTextField @bind-Value="_form.RootCause" Label="@L["observations.root_cause"]" Variant="Variant.Outlined"
                          FullWidth="true" Lines="2" />
        </MudItem>
    </MudGrid>

    <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-6" Spacing="2">
        <MudButton Variant="Variant.Outlined" OnClick='() => Nav.NavigateTo("/observations")'>@L["common.cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="Save" Disabled="_saving">
            @(_saving ? L["common.saving"] : L["observations.new"])
        </MudButton>
    </MudStack>
</MudPaper>

@code {
    private List<ProjectDto> _projects = [];
    private List<UserDto>    _users    = [];
    private bool _saving = false;
    private ObsForm _form = new();

    protected override async Task OnInitializedAsync()
    {
        L.OnChange += StateHasChanged;
        try
        {
            var t1 = Api.GetProjectsAsync();
            var t2 = Api.GetUsersAsync();
            await Task.WhenAll(t1, t2);
            _projects = t1.Result;
            _users    = t2.Result;
        }
        catch { Snackbar.Add(L["common.error_loading"], Severity.Error); }
    }

    public void Dispose() { L.OnChange -= StateHasChanged; }

    private async Task Save()
    {
        if (_form.ProjectId == Guid.Empty || string.IsNullOrWhiteSpace(_form.Title) || string.IsNullOrWhiteSpace(_form.Description))
        {
            Snackbar.Add(L["observations.validation_required"], Severity.Warning);
            return;
        }
        _saving = true;
        var ok = await Api.CreateObservationAsync(new
        {
            _form.ProjectId,
            _form.Title,
            _form.Description,
            Severity             = _form.Severity,
            _form.Category,
            _form.LocationDescription,
            AssignedToId         = _form.AssignedToId == Guid.Empty ? (Guid?)null : _form.AssignedToId,
            DueDate              = _form.DueDate.HasValue ? DateOnly.FromDateTime(_form.DueDate.Value).ToString("yyyy-MM-dd") : null,
            _form.RootCause
        });
        _saving = false;
        if (ok) { Snackbar.Add(L["observations.created"], Severity.Success); Nav.NavigateTo("/observations"); }
        else    Snackbar.Add(L["observations.error_creating"], Severity.Error);
    }

    private class ObsForm
    {
        public Guid      ProjectId           { get; set; }
        public string    Title               { get; set; } = string.Empty;
        public string    Description         { get; set; } = string.Empty;
        public string    Severity            { get; set; } = "Media";
        public string?   Category            { get; set; }
        public string?   LocationDescription { get; set; }
        public Guid      AssignedToId        { get; set; }
        public DateTime? DueDate             { get; set; }
        public string?   RootCause           { get; set; }
    }
}
