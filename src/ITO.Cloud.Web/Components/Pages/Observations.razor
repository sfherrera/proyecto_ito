@page "/observations"
@attribute [Authorize(Roles = "SuperAdmin,AdminTenant,Director,Supervisor,Inspector")]
@implements IDisposable

@using ITO.Cloud.Web.Auth
@inject ItoApiService Api
@inject ISnackbar Snackbar

<PageTitle>@L["observations.title"] — ITO Cloud</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5">
        <MudIcon Icon="@Icons.Material.Filled.Warning" Class="mr-2" />@L["observations.title"]
    </MudText>
    <MudSpacer />
    <HelpButton Module="observations" />
    <AuthorizeView Roles="SuperAdmin,AdminTenant,Director,Supervisor,Inspector">
        <MudButton Variant="Variant.Filled" Color="Color.Warning"
                   StartIcon="@Icons.Material.Filled.Add"
                   Href="/observations/new">
            @L["observations.new"]
        </MudButton>
    </AuthorizeView>
</MudStack>

<MudPaper Elevation="2">
    <MudTable Items="_observations" Hover="true" Striped="true" Loading="_loading"
              Filter="FilterFunc" Dense="true">
        <ToolBarContent>
            <MudTextField @bind-Value="_searchText" Placeholder="@L["common.search"]" Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" Class="mt-0" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>@L["common.code"]</MudTh>
            <MudTh>@L["common.title"]</MudTh>
            <MudTh>@L["observations.severity"]</MudTh>
            <MudTh>@L["common.status"]</MudTh>
            <MudTh>@L["observations.due_date"]</MudTh>
            <MudTh>@L["common.actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Warning">@context.Code</MudChip></MudTd>
            <MudTd>@context.Title</MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="@GetSeverityColor(context.Severity)">
                    @context.Severity
                </MudChip>
            </MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">
                    @context.Status
                </MudChip>
            </MudTd>
            <MudTd>
                @if (!string.IsNullOrEmpty(context.DueDate))
                {
                    <MudText Color="@(context.IsOverdue ? Color.Error : Color.Default)">
                        @context.DueDate
                        @if (context.IsOverdue) { <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Small" /> }
                    </MudText>
                }
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Primary"
                               Href="@($"/observations/{context.Id}")" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4">@L["observations.no_records"]</MudText>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

@code {
    private List<ObservationDto> _observations = [];
    private bool   _loading    = true;
    private string _searchText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        L.OnChange += StateHasChanged;
        try   { _observations = await Api.GetObservationsAsync(); }
        catch { Snackbar.Add(L["observations.error_loading"], Severity.Error); }
        finally { _loading = false; }
    }

    public void Dispose() { L.OnChange -= StateHasChanged; }

    private bool FilterFunc(ObservationDto o) =>
        string.IsNullOrEmpty(_searchText) ||
        o.Title.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
        o.Code.Contains(_searchText, StringComparison.OrdinalIgnoreCase);

    private static Color GetSeverityColor(string s) => s switch
    {
        "Critica" or "Critical" => Color.Error,
        "Alta"                  => Color.Warning,
        "Media"                 => Color.Info,
        _                       => Color.Default
    };

    private static Color GetStatusColor(string s) => s switch
    {
        "Abierta"    => Color.Warning,
        "Asignada"   => Color.Info,
        "EnRevision" => Color.Secondary,
        "Cerrada"    => Color.Success,
        "Rechazada"  => Color.Error,
        _            => Color.Default
    };
}
