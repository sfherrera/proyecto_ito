        "permiso"        => Color.Success,
        _                => Color.Default
    };

    private static string FormatFileSize(long? bytes)
    {
        if (!bytes.HasValue) return "—";
        return bytes.Value switch
        {
            < 1024       => $"{bytes.Value} B",
            < 1048576    => $"{bytes.Value / 1024.0:F1} KB",
            < 1073741824 => $"{bytes.Value / 1048576.0:F1} MB",
            _            => $"{bytes.Value / 1073741824.0:F1} GB"
        };
    }

    // ── Members ──────────────────────────────────────────────────────────────
    private async Task LoadMembers()
    {
        if (_membersLoaded) return;
        _loadingMembers = true;
        try
        {
            _members = await Api.GetProjectMembersAsync(Id);
            _membersLoaded = true;
        }
        catch { Snackbar.Add(L["projects.error_loading_members"], Severity.Error); }
        finally { _loadingMembers = false; }
    }

    private async Task OpenAddMemberDialog()
    {
        _memberForm = new MemberForm();
        try
        {
            _availableUsers = await Api.GetUsersAsync();
            // Filter out users already in the project
            var memberIds = _members.Select(m => m.UserId).ToHashSet();
            _availableUsers = _availableUsers.Where(u => !memberIds.Contains(u.Id)).ToList();
        }
        catch { Snackbar.Add(L["projects.error_loading_users"], Severity.Error); return; }
        _showMemberDialog = true;
    }

    private async Task SaveMember()
    {
        if (_memberForm.UserId == Guid.Empty)
        {
            Snackbar.Add(L["projects.select_user"], Severity.Warning);
            return;
        }
        _savingMember = true;
        var ok = await Api.AddProjectMemberAsync(Id, new
        {
            _memberForm.UserId,
            _memberForm.ProjectRole
        });
        _savingMember = false;
        if (ok)
        {
            Snackbar.Add(L["projects.member_added"], Severity.Success);
            _showMemberDialog = false;
            _membersLoaded = false;
            await LoadMembers();
        }
        else Snackbar.Add(L["projects.error_adding_member"], Severity.Error);
    }

    private async Task RemoveMember(Guid memberId)
    {
        var ok = await Api.RemoveProjectMemberAsync(Id, memberId);
        if (ok)
        {
            Snackbar.Add(L["projects.member_removed"], Severity.Success);
            _membersLoaded = false;
            await LoadMembers();
        }
        else Snackbar.Add(L["projects.error_removing_member"], Severity.Error);
    }

