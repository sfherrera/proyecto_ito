@page "/projects"
@attribute [Authorize(Roles = "SuperAdmin,AdminTenant,Director,Supervisor,Inspector")]
@implements IDisposable

@using ITO.Cloud.Web.Auth
@inject ItoApiService Api
@inject ISnackbar Snackbar

<PageTitle>@L["projects.title"] — ITO Cloud</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5">
        <MudIcon Icon="@Icons.Material.Filled.AccountTree" Class="mr-2" />@L["projects.title"]
    </MudText>
    <MudSpacer />
    <HelpButton Module="projects" />
    <AuthorizeView Roles="SuperAdmin,AdminTenant,Director">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   Href="/projects/new">
            @L["projects.new"]
        </MudButton>
    </AuthorizeView>
</MudStack>

<MudPaper Elevation="2">
    <MudTable Items="_projects" Hover="true" Striped="true" Loading="_loading"
              Filter="FilterFunc" Dense="true">
        <ToolBarContent>
            <MudTextField @bind-Value="_searchText" Placeholder="@L["common.search"]" Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"
                          Class="mt-0" Immediate="true" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>@L["common.code"]</MudTh>
            <MudTh>@L["common.name"]</MudTh>
            <MudTh>@L["projects.company"]</MudTh>
            <MudTh>@L["common.status"]</MudTh>
            <MudTh>@L["projects.start"]</MudTh>
            <MudTh>@L["common.actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Primary">@context.Code</MudChip></MudTd>
            <MudTd>@context.Name</MudTd>
            <MudTd>@context.CompanyName</MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">
                    @context.Status
                </MudChip>
            </MudTd>
            <MudTd>@context.StartDate</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Primary"
                               Href="@($"/projects/{context.Id}")" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4">@L["projects.no_records"]</MudText>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

@code {
    private List<ProjectDto> _projects = [];
    private bool   _loading    = true;
    private string _searchText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        L.OnChange += StateHasChanged;
        try   { _projects = await Api.GetProjectsAsync(); }
        catch { Snackbar.Add(L["projects.error_loading"], Severity.Error); }
        finally { _loading = false; }
    }

    public void Dispose() { L.OnChange -= StateHasChanged; }

    private bool FilterFunc(ProjectDto p) =>
        string.IsNullOrEmpty(_searchText) ||
        p.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
        p.Code.Contains(_searchText, StringComparison.OrdinalIgnoreCase);

    private static Color GetStatusColor(string? s) => s switch
    {
        "Activo"     => Color.Success,
        "Paralizado" => Color.Warning,
        "Terminado"  => Color.Default,
        _            => Color.Info
    };
}
