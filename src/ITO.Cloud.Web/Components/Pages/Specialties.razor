@page "/specialties"
@attribute [Authorize(Roles = "SuperAdmin,AdminTenant,Director,Supervisor")]
@implements IDisposable

@using ITO.Cloud.Web.Auth
@inject ItoApiService Api
@inject ISnackbar Snackbar

<PageTitle>@L["specialties.title"] — ITO Cloud</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5">
        <MudIcon Icon="@Icons.Material.Filled.Category" Class="mr-2" />@L["specialties.title"]
    </MudText>
    <MudSpacer />
    <HelpButton Module="specialties" />
    <AuthorizeView Roles="SuperAdmin,AdminTenant">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenCreateDialog">
            @L["specialties.new"]
        </MudButton>
    </AuthorizeView>
</MudStack>

<MudPaper Elevation="2">
    <MudTable Items="_specialties" Hover="true" Striped="true" Loading="_loading"
              Filter="FilterFunc" Dense="true">
        <ToolBarContent>
            <MudTextField @bind-Value="_searchText" Placeholder="@L["common.search"]" Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"
                          Class="mt-0" Immediate="true" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>@L["common.name"]</MudTh>
            <MudTh>@L["common.code"]</MudTh>
            <MudTh>@L["common.color"]</MudTh>
            <MudTh>@L["common.status"]</MudTh>
            <MudTh>@L["common.actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd>@context.Code</MudTd>
            <MudTd>
                @if (!string.IsNullOrEmpty(context.Color))
                {
                    <MudChip T="string" Style="@($"background-color:{context.Color};color:white")" Size="Size.Small">
                        @context.Color
                    </MudChip>
                }
            </MudTd>
            <MudTd>
                <MudChip T="string" Color="@(context.IsActive ? Color.Success : Color.Default)" Size="Size.Small">
                    @(context.IsActive ? L["common.active_f"] : L["common.inactive_f"])
                </MudChip>
            </MudTd>
            <MudTd>
                <AuthorizeView Roles="SuperAdmin,AdminTenant" Context="_ac">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                   OnClick="() => OpenEditDialog(context)" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   OnClick="() => DeleteSpecialty(context.Id)" />
                </AuthorizeView>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4">@L["specialties.no_records"]</MudText>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

<!-- Dialog crear / editar especialidad -->
<MudDialog @bind-Visible="_showDialog">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editId.HasValue ? L["specialties.edit"] : L["specialties.new"])</MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="_form.Name" Label="@(L["common.name"] + " *")" Variant="Variant.Outlined" FullWidth="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_form.Code" Label="@L["common.code"]" Variant="Variant.Outlined" FullWidth="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_form.Color" Label="@L["specialties.color_hint"]" Variant="Variant.Outlined" FullWidth="true" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_form.Description" Label="@L["common.description"]" Variant="Variant.Outlined" FullWidth="true" Lines="3" />
            </MudItem>
            @if (_editId.HasValue)
            {
                <MudItem xs="12">
                    <MudSwitch @bind-Value="_form.IsActive" Label="@L["common.active_f"]" Color="Color.Success" />
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showDialog = false">@L["common.cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSpecialty" Disabled="_saving">
            @(_saving ? L["common.saving"] : L["common.save"])
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<SpecialtyDto> _specialties = [];
    private bool   _loading    = true;
    private bool   _showDialog = false;
    private bool   _saving     = false;
    private string _searchText = string.Empty;
    private Guid?  _editId;
    private SpecialtyForm _form = new();

    protected override async Task OnInitializedAsync()
    {
        L.OnChange += StateHasChanged;
        await LoadSpecialties();
    }

    public void Dispose()
    {
        L.OnChange -= StateHasChanged;
    }

    private async Task LoadSpecialties()
    {
        _loading = true;
        try   { _specialties = await Api.GetSpecialtiesAsync(); }
        catch { Snackbar.Add(L["specialties.error_loading"], Severity.Error); }
        finally { _loading = false; }
    }

    private bool FilterFunc(SpecialtyDto s) =>
        string.IsNullOrEmpty(_searchText) ||
        s.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
        (s.Code?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false);

    private void OpenCreateDialog()
    {
        _editId = null;
        _form   = new();
        _showDialog = true;
    }

    private void OpenEditDialog(SpecialtyDto item)
    {
        _editId = item.Id;
        _form   = new()
        {
            Name        = item.Name,
            Code        = item.Code,
            Description = item.Description,
            Color       = item.Color,
            IsActive    = item.IsActive
        };
        _showDialog = true;
    }

    private async Task SaveSpecialty()
    {
        if (string.IsNullOrWhiteSpace(_form.Name)) return;
        _saving = true;

        bool ok;
        if (_editId.HasValue)
        {
            ok = await Api.UpdateSpecialtyAsync(_editId.Value, new
            {
                _form.Name, _form.Code, _form.Description, _form.Color, _form.IsActive
            });
        }
        else
        {
            ok = await Api.CreateSpecialtyAsync(new
            {
                _form.Name, _form.Code, _form.Description, _form.Color
            });
        }

        _saving     = false;
        _showDialog = false;
        if (ok) { Snackbar.Add(_editId.HasValue ? L["specialties.updated"] : L["specialties.created"], Severity.Success); await LoadSpecialties(); }
        else    Snackbar.Add(L["specialties.error_saving"], Severity.Error);
    }

    private async Task DeleteSpecialty(Guid id)
    {
        var ok = await Api.DeleteSpecialtyAsync(id);
        if (ok) { Snackbar.Add(L["specialties.deleted"], Severity.Success); await LoadSpecialties(); }
        else    Snackbar.Add(L["specialties.error_deleting"], Severity.Error);
    }

    private class SpecialtyForm
    {
        public string  Name        { get; set; } = string.Empty;
        public string? Code        { get; set; }
        public string? Description { get; set; }
        public string? Color       { get; set; }
        public bool    IsActive    { get; set; } = true;
    }
}
