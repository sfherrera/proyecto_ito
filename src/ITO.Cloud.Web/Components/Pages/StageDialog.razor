@* Dialog for creating/editing a project stage *@
<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(IsEdit ? "Editar Etapa" : "Nueva Etapa")</MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="Name" Label="Nombre *" Variant="Variant.Outlined" FullWidth="true" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="Description" Label="Descripción" Variant="Variant.Outlined"
                              FullWidth="true" Lines="2" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="OrderIndex" Label="Orden" Variant="Variant.Outlined" FullWidth="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect @bind-Value="Status" Label="Estado" Variant="Variant.Outlined" FullWidth="true">
                    <MudSelectItem Value="@("pendiente")">Pendiente</MudSelectItem>
                    <MudSelectItem Value="@("en_progreso")">En Progreso</MudSelectItem>
                    <MudSelectItem Value="@("completada")">Completada</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="_startDateTime" Label="Fecha Inicio" Variant="Variant.Outlined"
                               DateFormat="yyyy-MM-dd" FullWidth="true" Clearable="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="_endDateTime" Label="Fecha Término" Variant="Variant.Outlined"
                               DateFormat="yyyy-MM-dd" FullWidth="true" Clearable="true" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit"
                   Disabled="@string.IsNullOrWhiteSpace(Name)">
            @(IsEdit ? "Guardar" : "Crear")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public bool IsEdit { get; set; }
    [Parameter] public string Name { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }
    [Parameter] public int OrderIndex { get; set; }
    [Parameter] public string Status { get; set; } = "pendiente";
    [Parameter] public DateOnly? StartDate { get; set; }
    [Parameter] public DateOnly? EndDate { get; set; }

    private DateTime? _startDateTime;
    private DateTime? _endDateTime;

    protected override void OnInitialized()
    {
        _startDateTime = StartDate.HasValue ? StartDate.Value.ToDateTime(TimeOnly.MinValue) : null;
        _endDateTime   = EndDate.HasValue ? EndDate.Value.ToDateTime(TimeOnly.MinValue) : null;
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        var startDate = _startDateTime.HasValue ? DateOnly.FromDateTime(_startDateTime.Value) : (DateOnly?)null;
        var endDate   = _endDateTime.HasValue ? DateOnly.FromDateTime(_endDateTime.Value) : (DateOnly?)null;

        MudDialog.Close(DialogResult.Ok(new StageDialogResult(Name, Description, OrderIndex, Status, startDate, endDate)));
    }
}
