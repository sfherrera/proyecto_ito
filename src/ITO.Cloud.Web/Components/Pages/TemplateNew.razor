@page "/templates/new"
@attribute [Authorize(Roles = "SuperAdmin,AdminTenant,Director")]
@implements IDisposable

@using ITO.Cloud.Web.Auth
@inject ItoApiService Api
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>@L["templates.new_title"] — ITO Cloud</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick='() => Nav.NavigateTo("/templates")' />
    <MudText Typo="Typo.h5">@L["templates.new_title"]</MudText>
</MudStack>

<MudPaper Elevation="2" Class="pa-6" Style="max-width:800px">
    <MudGrid>
        <MudItem xs="12">
            <MudTextField @bind-Value="_form.Name" Label="@(L["common.name"] + " *")" Variant="Variant.Outlined" FullWidth="true" />
        </MudItem>
        <MudItem xs="12">
            <MudTextField @bind-Value="_form.Description" Label="@L["common.description"]" Variant="Variant.Outlined"
                          FullWidth="true" Lines="3" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudSelect @bind-Value="_form.TemplateType" Label="@L["templates.template_type"]" Variant="Variant.Outlined" FullWidth="true">
                <MudSelectItem Value="@("obra_gruesa")">@L["templates.type_obra_gruesa"]</MudSelectItem>
                <MudSelectItem Value="@("terminaciones")">@L["templates.type_terminaciones"]</MudSelectItem>
                <MudSelectItem Value="@("recepcion")">@L["templates.type_recepcion"]</MudSelectItem>
                <MudSelectItem Value="@("seguridad")">@L["templates.type_seguridad"]</MudSelectItem>
                <MudSelectItem Value="@("instalaciones")">@L["templates.type_instalaciones"]</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudNumericField @bind-Value="_form.PassingScore" Label="@L["templates.passing_score"]" Variant="Variant.Outlined"
                             FullWidth="true" Min="0" Max="100" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudSwitch @bind-Value="_form.RequireGeolocation" Label="@L["templates.require_geolocation"]" Color="Color.Primary" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudSwitch @bind-Value="_form.RequireSignature" Label="@L["templates.require_signature"]" Color="Color.Primary" />
        </MudItem>
    </MudGrid>

    <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-6" Spacing="2">
        <MudButton Variant="Variant.Outlined" OnClick='() => Nav.NavigateTo("/templates")'>@L["common.cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="_saving">
            @(_saving ? L["common.saving"] : L["templates.new"])
        </MudButton>
    </MudStack>
</MudPaper>

@code {
    private bool _saving = false;
    private TemplateForm _form = new();

    protected override void OnInitialized()
    {
        L.OnChange += StateHasChanged;
    }

    public void Dispose() { L.OnChange -= StateHasChanged; }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_form.Name))
        {
            Snackbar.Add(L["templates.name_required"], Severity.Warning);
            return;
        }
        _saving = true;
        var result = await Api.CreateTemplateAsync(new
        {
            _form.Name,
            _form.Description,
            _form.TemplateType,
            _form.PassingScore,
            _form.RequireGeolocation,
            _form.RequireSignature
        });
        _saving = false;
        if (result != null)
        {
            Snackbar.Add(L["templates.created"], Severity.Success);
            Nav.NavigateTo($"/templates/{result}");
        }
        else
        {
            Snackbar.Add(L["templates.error_creating"], Severity.Error);
        }
    }

    private class TemplateForm
    {
        public string  Name               { get; set; } = string.Empty;
        public string? Description        { get; set; }
        public string  TemplateType       { get; set; } = "obra_gruesa";
        public decimal? PassingScore      { get; set; } = 70;
        public bool    RequireGeolocation { get; set; } = false;
        public bool    RequireSignature   { get; set; } = false;
    }
}
