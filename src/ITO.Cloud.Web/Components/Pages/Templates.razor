@page "/templates"
@attribute [Authorize(Roles = "SuperAdmin,AdminTenant,Director,Supervisor,Inspector")]
@implements IDisposable

@using ITO.Cloud.Web.Auth
@inject ItoApiService Api
@inject ISnackbar Snackbar

<PageTitle>@L["templates.title"] — ITO Cloud</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5">
        <MudIcon Icon="@Icons.Material.Filled.ListAlt" Class="mr-2" />@L["templates.title"]
    </MudText>
    <MudSpacer />
    <HelpButton Module="templates" />
    <AuthorizeView Roles="SuperAdmin,AdminTenant,Director">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   Href="/templates/new">
            @L["templates.new"]
        </MudButton>
    </AuthorizeView>
</MudStack>

<MudPaper Elevation="2">
    <MudTable Items="_templates" Hover="true" Striped="true" Loading="_loading"
              Filter="FilterFunc" Dense="true">
        <ToolBarContent>
            <MudTextField @bind-Value="_searchText" Placeholder="@L["templates.search"]" Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" Class="mt-0" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>@L["common.name"]</MudTh>
            <MudTh>@L["common.type"]</MudTh>
            <MudTh>@L["common.status"]</MudTh>
            <MudTh>@L["common.actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="Color.Info">
                    @FormatType(context.TemplateType)
                </MudChip>
            </MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">
                    @context.Status
                </MudChip>
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Primary"
                               Href="@($"/templates/{context.Id}")" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4">@L["templates.no_records"]</MudText>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

@code {
    private List<TemplateItemDto> _templates = [];
    private bool   _loading    = true;
    private string _searchText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        L.OnChange += StateHasChanged;
        try   { _templates = await Api.GetTemplatesAsync(); }
        catch { Snackbar.Add(L["templates.error_loading"], Severity.Error); }
        finally { _loading = false; }
    }

    public void Dispose() { L.OnChange -= StateHasChanged; }

    private bool FilterFunc(TemplateItemDto t) =>
        string.IsNullOrEmpty(_searchText) ||
        t.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase);

    private string FormatType(string? type) => type switch
    {
        "obra_gruesa"   => L["templates.type_obra_gruesa"],
        "terminaciones" => L["templates.type_terminaciones"],
        "recepcion"     => L["templates.type_recepcion"],
        "seguridad"     => L["templates.type_seguridad"],
        _               => type ?? L["templates.type_general"]
    };

    private static Color GetStatusColor(string s) => s switch
    {
        "Activa"    => Color.Success,
        "Borrador"  => Color.Warning,
        "Inactiva"  => Color.Default,
        "Archivada" => Color.Error,
        _           => Color.Default
    };
}
