@page "/users"
@attribute [Authorize(Roles = "SuperAdmin,AdminTenant,Director")]
@implements IDisposable

@using ITO.Cloud.Web.Auth
@inject ItoApiService Api
@inject ISnackbar Snackbar

<PageTitle>@L["users.title"] — ITO Cloud</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5">
        <MudIcon Icon="@Icons.Material.Filled.People" Class="mr-2" />@L["users.title"]
    </MudText>
    <MudSpacer />
    <HelpButton Module="users" />
    <AuthorizeView Roles="SuperAdmin,AdminTenant">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.PersonAdd"
                   OnClick="OpenCreateDialog">
            @L["users.new"]
        </MudButton>
    </AuthorizeView>
</MudStack>

<MudPaper Elevation="2">
    <MudTable Items="_users" Hover="true" Striped="true" Loading="_loading"
              Filter="FilterFunc" Dense="true">
        <ToolBarContent>
            <MudTextField @bind-Value="_searchText" Placeholder="@L["common.search"]" Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" Class="mt-0" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>@L["common.name"]</MudTh>
            <MudTh>@L["common.email"]</MudTh>
            <MudTh>@L["users.position"]</MudTh>
            <MudTh>@L["users.roles"]</MudTh>
            <MudTh>@L["common.status"]</MudTh>
            <MudTh>@L["common.actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.FullName</MudTd>
            <MudTd>@context.Email</MudTd>
            <MudTd>@context.Position</MudTd>
            <MudTd>
                @foreach (var r in context.Roles ?? [])
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Class="mr-1">@r</MudChip>
                }
            </MudTd>
            <MudTd>
                <MudChip T="string" Color="@(context.IsActive ? Color.Success : Color.Default)" Size="Size.Small">
                    @(context.IsActive ? L["common.active_m"] : L["common.inactive_m"])
                </MudChip>
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                               OnClick="() => OpenEditDialog(context)" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4">@L["users.no_records"]</MudText>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

<!-- Dialog crear / editar usuario -->
<MudDialog @bind-Visible="_showDialog">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editId.HasValue ? L["users.edit"] : L["users.new"])</MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_form.FirstName" Label="@L["users.first_name"]" Variant="Variant.Outlined" FullWidth="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_form.LastName" Label="@L["users.last_name"]" Variant="Variant.Outlined" FullWidth="true" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_form.Email" Label="@(L["common.email"] + " *")" InputType="InputType.Email"
                              Variant="Variant.Outlined" FullWidth="true" Disabled="_editId.HasValue" />
            </MudItem>
            @if (!_editId.HasValue)
            {
                <MudItem xs="12">
                    <MudTextField @bind-Value="_form.Password" Label="@L["users.password"]" InputType="InputType.Password"
                                  Variant="Variant.Outlined" FullWidth="true" />
                </MudItem>
            }
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_form.Rut" Label="@L["common.rut"]" Variant="Variant.Outlined" FullWidth="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_form.Position" Label="@L["users.position"]" Variant="Variant.Outlined" FullWidth="true" />
            </MudItem>
            @if (!_editId.HasValue)
            {
                <MudItem xs="12">
                    <MudSelect @bind-Value="_form.Role" Label="@L["users.role"]" Variant="Variant.Outlined" FullWidth="true">
                        <MudSelectItem Value="@("Inspector")">@L["users.role_inspector"]</MudSelectItem>
                        <MudSelectItem Value="@("Supervisor")">@L["users.role_supervisor"]</MudSelectItem>
                        <MudSelectItem Value="@("Director")">@L["users.role_director"]</MudSelectItem>
                        <MudSelectItem Value="@("AdminTenant")">@L["users.role_admin"]</MudSelectItem>
                        <MudSelectItem Value="@("Contratista")">@L["users.role_contractor"]</MudSelectItem>
                    </MudSelect>
                </MudItem>
            }
            @if (_editId.HasValue)
            {
                <MudItem xs="12">
                    <MudSwitch @bind-Value="_form.IsActive" Label="@L["common.active_m"]" Color="Color.Success" />
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showDialog = false">@L["common.cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveUser" Disabled="_saving">
            @(_saving ? L["common.saving"] : L["common.save"])
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<UserDto> _users    = [];
    private bool   _loading         = true;
    private bool   _showDialog      = false;
    private bool   _saving          = false;
    private string _searchText      = string.Empty;
    private Guid?  _editId;
    private UserForm _form          = new();

    protected override async Task OnInitializedAsync()
    {
        L.OnChange += StateHasChanged;
        await LoadUsers();
    }

    public void Dispose() { L.OnChange -= StateHasChanged; }

    private async Task LoadUsers()
    {
        _loading = true;
        try   { _users = await Api.GetUsersAsync(); }
        catch { Snackbar.Add(L["users.error_loading"], Severity.Error); }
        finally { _loading = false; }
    }

    private bool FilterFunc(UserDto u) =>
        string.IsNullOrEmpty(_searchText) ||
        u.FullName.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
        u.Email.Contains(_searchText, StringComparison.OrdinalIgnoreCase);

    private void OpenCreateDialog()
    {
        _editId     = null;
        _form       = new();
        _showDialog = true;
    }

    private void OpenEditDialog(UserDto u)
    {
        _editId           = u.Id;
        _form             = new UserForm
        {
            FirstName = u.FirstName,
            LastName  = u.LastName,
            Email     = u.Email,
            Rut       = u.Rut,
            Position  = u.Position,
            IsActive  = u.IsActive
        };
        _showDialog = true;
    }

    private async Task SaveUser()
    {
        if (string.IsNullOrWhiteSpace(_form.FirstName) || string.IsNullOrWhiteSpace(_form.LastName)) return;
        _saving = true;

        bool ok;
        if (_editId.HasValue)
        {
            ok = await Api.UpdateUserAsync(_editId.Value, new
            {
                _form.FirstName, _form.LastName, _form.Rut, _form.Position, _form.IsActive
            });
        }
        else
        {
            if (string.IsNullOrWhiteSpace(_form.Email) || string.IsNullOrWhiteSpace(_form.Password))
            {
                Snackbar.Add(L["users.validation_required"], Severity.Warning);
                _saving = false;
                return;
            }
            ok = await Api.CreateUserAsync(new
            {
                _form.FirstName, _form.LastName, _form.Email, _form.Password,
                _form.Rut, _form.Position,
                Roles = new[] { _form.Role }
            });
        }

        _saving     = false;
        _showDialog = false;
        if (ok) { Snackbar.Add(_editId.HasValue ? L["users.updated"] : L["users.created"], Severity.Success); await LoadUsers(); }
        else    Snackbar.Add(L["users.error_saving"], Severity.Error);
    }

    private class UserForm
    {
        public string FirstName { get; set; } = string.Empty;
        public string LastName  { get; set; } = string.Empty;
        public string Email     { get; set; } = string.Empty;
        public string Password  { get; set; } = string.Empty;
        public string? Rut      { get; set; }
        public string? Position { get; set; }
        public string Role      { get; set; } = "Inspector";
        public bool   IsActive  { get; set; } = true;
    }
}
